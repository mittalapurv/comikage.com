# Contact form delivery — sends through your own Gmail via SMTP.
#
# GMAIL_APP_PASSWORD is NOT your normal Gmail password. Google requires a one-off
# "App Password" for websites/apps:
#   1. Enable 2-Step Verification on the Google account (myaccount.google.com/security)
#   2. Create an App Password at myaccount.google.com/apppasswords (name it "comikage website")
#   3. Paste the 16-character password below (spaces don't matter)
#
# Local dev: put these in .env.local. Production (VPS): add them to /opt/comikage/.env.production —
# docker-compose passes them into the app container.
GMAIL_USER=a29npvtltd@gmail.com
GMAIL_APP_PASSWORD=

# Where enquiries are delivered. Defaults to a29npvtltd@gmail.com if unset.
CONTACT_TO_EMAIL=a29npvtltd@gmail.com
